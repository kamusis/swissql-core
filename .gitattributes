# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Explicitly LF for source files
*.java text eol=lf
*.go text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.sh text eol=lf

# Binary files — no line ending conversion
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
